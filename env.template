# ============================================
# Phantom Tac Toe - Environment Variables
# Copy this file to .env and fill in your values
# ============================================

# ---- Clerk Authentication ----
# Get your key from https://dashboard.clerk.com
VITE_CLERK_PUBLISHABLE_KEY=pk_test_your_key_here

# ---- Site Configuration ---- #
# The public URL of your deployed site (used for share links and OG meta)
VITE_SITE_URL=https://phantomtactoe.mreshank.com

# ---- Convex (Storage & Global Leaderboard) ---- #
VITE_CONVEX_URL=https://your-project-name.convex.cloud

# ---- PeerJS (Multiplayer) ---- #
# PeerJS signaling server configuration
# Default: Public PeerJS cloud server (0.peerjs.com)
# For production, consider hosting your own PeerJS server
VITE_PEERJS_HOST=0.peerjs.com
VITE_PEERJS_PORT=443

# ---- Analytics (Optional) ---- #
# Google Analytics Measurement ID
VITE_GA_ID=

# Google Tag Manager Container ID
VITE_GTM_ID=

# ---- Social / Sharing ---- #
# Default OG image URL (override if hosting assets on CDN)
VITE_OG_IMAGE_URL=https://phantomtactoe.mreshank.com/og-image.png
